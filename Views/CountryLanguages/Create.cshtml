@model WorldApp.Models.CountryLanguage
@{
    ViewData["Title"] = "Agregar idioma";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-0 pt-4">
                <h2 class="display-6 fw-semibold"><i class="fas fa-language me-2"></i> Agregar idioma</h2>
                <p class="text-muted">Asocie un idioma a un país</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="CountryCode" class="form-label fw-semibold">País</label>
                        <select asp-for="CountryCode" class="form-select" asp-items="ViewBag.CountryCode">
                            <option value="">-- Seleccione un país --</option>
                        </select>
                        <span asp-validation-for="CountryCode" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Language" class="form-label fw-semibold">Idioma</label>
                        <input asp-for="Language" class="form-control" placeholder="Español" />
                        <span asp-validation-for="Language" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="IsOfficial" class="form-label fw-semibold">¿Oficial?</label>
                        <select asp-for="IsOfficial" class="form-select">
                            <option value="T">Sí, es oficial</option>
                            <option value="F">No, es regional o minoritario</option>
                        </select>
                        <span asp-validation-for="IsOfficial" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Percentage" class="form-label fw-semibold">Porcentaje de hablantes</label>
                        <input asp-for="Percentage" class="form-control" step="0.1" placeholder="Ej. 75.5" />
                        <span asp-validation-for="Percentage" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Cancelar</a>
                        <button type="submit" class="btn btn-dark rounded-pill px-4">Guardar idioma</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}