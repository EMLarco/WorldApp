@model WorldApp.Models.CountryLanguage
@{
    ViewData["Title"] = "Editar idioma";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-0 pt-4">
                <h2 class="h3 mb-0"><i class="fas fa-edit me-2"></i> Editar idioma</h2>
                <p class="text-muted mt-2">Modifique el registro de idioma</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <input type="hidden" asp-for="CountryCode" />
                    <input type="hidden" asp-for="Language" />
                    <input type="hidden" asp-for="IsDeleted" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">País</label>
                        <input class="form-control" value="@(Model.Country?.Name ?? Model.CountryCode)" disabled />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Idioma</label>
                        <input class="form-control" value="@Model.Language" disabled />
                    </div>
                    <div class="mb-3">
                        <label asp-for="IsOfficial" class="form-label fw-semibold">¿Es oficial?</label>
                        <select asp-for="IsOfficial" class="form-select">
                            <option value="T">Sí, oficial</option>
                            <option value="F">No oficial</option>
                        </select>
                        <span asp-validation-for="IsOfficial" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Percentage" class="form-label fw-semibold">Porcentaje</label>
                        <div class="input-group">
                            <input asp-for="Percentage" class="form-control" step="0.1" />
                            <span class="input-group-text">%</span>
                        </div>
                        <span asp-validation-for="Percentage" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between gap-2">
                        <button type="submit" class="btn btn-dark rounded-pill px-4 py-2"><i class="fas fa-save me-1"></i> Actualizar</button>
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 py-2"><i class="fas fa-times me-1"></i> Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}