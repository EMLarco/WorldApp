@model WorldApp.Models.Country
@{
    ViewData["Title"] = "Nuevo país";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-0 pt-4">
                <h2 class="display-6 fw-semibold"><i class="fas fa-globe-americas me-2"></i> Nuevo país</h2>
                <p class="text-muted">Ingrese los datos del país</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Code" class="form-label fw-semibold">Código (3 letras)</label>
                            <input asp-for="Code" class="form-control" placeholder="COL" maxlength="3" />
                            <span asp-validation-for="Code" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Code2" class="form-label fw-semibold">Código 2 letras</label>
                            <input asp-for="Code2" class="form-control" placeholder="CO" maxlength="2" />
                            <span asp-validation-for="Code2" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">Nombre del país</label>
                        <input asp-for="Name" class="form-control" placeholder="Colombia" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Continent" class="form-label fw-semibold">Continente</label>
                            <input asp-for="Continent" class="form-control" placeholder="South America" />
                            <span asp-validation-for="Continent" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Region" class="form-label fw-semibold">Región</label>
                            <input asp-for="Region" class="form-control" placeholder="South America" />
                            <span asp-validation-for="Region" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="SurfaceArea" class="form-label fw-semibold">Área (km²)</label>
                            <input asp-for="SurfaceArea" class="form-control" step="0.01" />
                            <span asp-validation-for="SurfaceArea" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="IndepYear" class="form-label fw-semibold">Año independencia</label>
                            <input asp-for="IndepYear" class="form-control" />
                            <span asp-validation-for="IndepYear" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Population" class="form-label fw-semibold">Población</label>
                            <input asp-for="Population" class="form-control" type="number" />
                            <span asp-validation-for="Population" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="LifeExpectancy" class="form-label">Esperanza de vida</label>
                            <input asp-for="LifeExpectancy" class="form-control" step="0.1" />
                            <span asp-validation-for="LifeExpectancy" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="GNP" class="form-label">PIB</label>
                            <input asp-for="GNP" class="form-control" step="0.01" />
                            <span asp-validation-for="GNP" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="GNPOld" class="form-label">PIB antiguo</label>
                            <input asp-for="GNPOld" class="form-control" step="0.01" />
                            <span asp-validation-for="GNPOld" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="LocalName" class="form-label">Nombre local</label>
                        <input asp-for="LocalName" class="form-control" />
                        <span asp-validation-for="LocalName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="GovernmentForm" class="form-label">Forma de gobierno</label>
                        <input asp-for="GovernmentForm" class="form-control" />
                        <span asp-validation-for="GovernmentForm" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="HeadOfState" class="form-label">Jefe de Estado</label>
                        <input asp-for="HeadOfState" class="form-control" />
                        <span asp-validation-for="HeadOfState" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Capital" class="form-label">ID Capital</label>
                        <input asp-for="Capital" class="form-control" />
                        <span asp-validation-for="Capital" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Cancelar</a>
                        <button type="submit" class="btn btn-dark rounded-pill px-4">Guardar país</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}