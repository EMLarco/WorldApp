<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WorldApp</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
            /* Fondo global con imagen y overlay oscuro */
            body {
                background: url('https://images.pexels.com/photos/466685/pexels-photo-466685.jpeg?auto=compress&cs=tinysrgb&w=1600') no-repeat center center fixed;
                background-size: cover;
                position: relative;
                margin: 0;
                padding: 0;
            }

                body::before {
                    content: "";
                    position: fixed;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 100%;
                    background-color: rgba(0, 0, 0, 0.6);
                    z-index: -1;
                }

            /* Navbar semi-transparente que combina con el diseño del login */
            .navbar {
                background-color: rgba(0, 0, 0, 0.8) !important;
                backdrop-filter: blur(4px);
                border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            }

            .navbar-brand, .navbar-nav .nav-link {
                color: #ffffff !important;
                font-weight: 500;
                transition: color 0.2s;
            }

                .navbar-nav .nav-link:hover {
                    color: #cccccc !important;
                }

            .navbar-toggler {
                border-color: rgba(255, 255, 255, 0.5);
            }

            .navbar-toggler-icon {
                filter: invert(1);
            }

            /* Contenedor principal: fondo transparente para que se vea la imagen,
                       pero el contenido (tablas, tarjetas) tendrá fondo blanco */
            .main-container {
                background-color: transparent;
                min-height: calc(100vh - 130px);
                padding: 2rem 0;
            }

            /* Tarjetas y tablas: fondo blanco con sombra suave */
            .card, .table, .form-container {
                background-color: #ffffff;
                border-radius: 1rem;
                box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
            }

            .table {
                overflow: hidden;
            }

                .table thead {
                    background-color: #000;
                    color: white;
                }

            /* Botones personalizados (negros con hover) */
            .btn-outline-custom {
                border-color: #000;
                color: #000;
            }

                .btn-outline-custom:hover {
                    background-color: #000;
                    color: #fff;
                }

            /* Footer semi-transparente */
            footer {
                background-color: rgba(0, 0, 0, 0.8);
                color: #ccc;
                padding: 1rem;
                text-align: center;
                margin-top: 2rem;
                font-size: 0.9rem;
            }

                footer a {
                    color: #fff;
                    text-decoration: none;
                }

                    footer a:hover {
                        text-decoration: underline;
                    }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">WorldApp</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Cities" asp-action="Index">Ciudades</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Countries" asp-action="Index">Países</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="CountryLanguages" asp-action="Index">Idiomas</a></li>
                </ul>
                <ul class="navbar-nav">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item"><span class="nav-link">Hola, @User.Identity.Name</span></li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="btn nav-link btn-link" style="color:white;">Cerrar sesión</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Register">Registrarse</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Iniciar sesión</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="main-container">
        <div class="container">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </div>

    <footer>
        <div class="container">
            &copy; 2026 - WorldApp | Sistema de gestión de ciudades, países e idiomas
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

    <!-- Script para manejar sesiones por pestaña (multisesión) -->
    <script>
        (function() {
        let tabId = sessionStorage.getItem('tabId');
        if (!tabId) {
        tabId = crypto.randomUUID ? crypto.randomUUID() : Math.random().toString(36).substring(2);
        sessionStorage.setItem('tabId', tabId);
        }
        function addTabIdToUrl(url) {
        try {
        let urlObj = new URL(url, window.location.href);
        if (!urlObj.searchParams.has('tabId')) {
        urlObj.searchParams.set('tabId', tabId);
        }
        return urlObj.toString();
        } catch(e) {
        let separator = url.indexOf('?') === -1 ? '?' : '&';
        return url + separator + 'tabId=' + encodeURIComponent(tabId);
        }
        }
        document.querySelectorAll('a[href]').forEach(link => {
        let originalHref = link.getAttribute('href');
        if (originalHref && !originalHref.startsWith('#') && !originalHref.startsWith('javascript:')) {
        link.href = addTabIdToUrl(originalHref);
        }
        });
        document.querySelectorAll('form').forEach(form => {
        if (!form.querySelector('input[name="tabId"]')) {
        let hidden = document.createElement('input');
        hidden.type = 'hidden';
        hidden.name = 'tabId';
        hidden.value = tabId;
        form.appendChild(hidden);
        }
        let action = form.getAttribute('action');
        if (action && action !== '#') {
        form.action = addTabIdToUrl(action);
        }
        });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>