@model WorldApp.Models.City
@{
    ViewData["Title"] = "Nueva ciudad";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-0 pt-4">
                <h2 class="display-6 fw-semibold"><i class="fas fa-city me-2"></i> Nueva ciudad</h2>
                <p class="text-muted">Complete la información de la ciudad</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">Nombre de la ciudad</label>
                        <input asp-for="Name" class="form-control" placeholder="Ej. Bogotá" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CountryCode" class="form-label fw-semibold">País</label>
                        <select asp-for="CountryCode" class="form-select" asp-items="ViewBag.CountryCode">
                            <option value="">-- Seleccione un país --</option>
                        </select>
                        <span asp-validation-for="CountryCode" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="District" class="form-label fw-semibold">Distrito / Departamento</label>
                        <input asp-for="District" class="form-control" placeholder="Ej. Cundinamarca" />
                        <span asp-validation-for="District" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Population" class="form-label fw-semibold">Población</label>
                        <input asp-for="Population" class="form-control" type="number" placeholder="0" />
                        <span asp-validation-for="Population" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                            <i class="fas fa-arrow-left me-1"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-dark rounded-pill px-4">
                            <i class="fas fa-save me-1"></i> Guardar ciudad
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}