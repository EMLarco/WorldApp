@model WorldApp.Models.City
@{
    ViewData["Title"] = "Detalles de la ciudad";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-0 pt-4">
                <h2 class="h3 mb-0"><i class="fas fa-info-circle me-2"></i> Detalles de la ciudad</h2>
            </div>
            <div class="card-body p-4">
                <dl class="row mb-0">
                    <dt class="col-sm-4 fw-semibold">ID</dt>
                    <dd class="col-sm-8">@Model.Id</dd>

                    <dt class="col-sm-4 fw-semibold">Nombre</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4 fw-semibold">País</dt>
                    <dd class="col-sm-8">@(Model.Country?.Name ?? Model.CountryCode)</dd>

                    <dt class="col-sm-4 fw-semibold">Distrito</dt>
                    <dd class="col-sm-8">@Model.District</dd>

                    <dt class="col-sm-4 fw-semibold">Población</dt>
                    <dd class="col-sm-8">@Model.Population.ToString("N0")</dd>
                </dl>
            </div>
            <div class="card-footer bg-white border-0 pb-4">
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-dark rounded-pill px-4">
                        <i class="fas fa-edit me-1"></i> Editar
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                        <i class="fas fa-arrow-left me-1"></i> Volver al listado
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>